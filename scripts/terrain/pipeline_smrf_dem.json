{
  "pipeline": [
    "REPLACE_WITH_INPUT.laz",
    {
      "type": "filters.smrf",
      "cell": 1.0,
      "slope": 0.15,
      "threshold": 0.5,
      "window": 18.0
    },
    {
      "type": "filters.range",
      "limits": "Classification[2:2]"
    },
    {
      "type": "writers.gdal",
      "filename": "REPLACE_WITH_OUTPUT.tif",
      "resolution": 1.0,
      "output_type": "all",
      "dimension": "Z",
      "gdalopts": "TILED=YES,COMPRESS=LZW"
    }
  ]
}
